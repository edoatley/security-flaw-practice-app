# Copy this file to .env.local and fill in values from your SST deploy outputs
VITE_API_URL=https://<api-id>.execute-api.eu-west-2.amazonaws.com
VITE_COGNITO_DOMAIN=https://<cognito-domain-prefix>.auth.eu-west-2.amazoncognito.com
VITE_COGNITO_CLIENT_ID=<cognito-client-id>
VITE_COGNITO_REDIRECT_URI=https://localhost:5173/auth/callback
