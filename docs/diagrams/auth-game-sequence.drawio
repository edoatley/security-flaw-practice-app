        <mxCell id="s5-box" value="⑤ Nightly Speed Median Computation (EventBridge Cron)" style="swimlane;startSize=20;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
