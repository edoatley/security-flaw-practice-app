        <mxCell id="cf-spa" value="CloudFront Distribution&#xa;(SPA Frontend)&#xa;&#xa;• Security Headers Policy&#xa;  (CSP, HSTS, X-Frame-Options)&#xa;• Redirect HTTP→HTTPS&#xa;• d34cxgc9obzwga.cloudfront.net" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudfront;labelBackgroundColor=none;sketch=0;html=1;fontSize=10;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="cf-spa-group">
