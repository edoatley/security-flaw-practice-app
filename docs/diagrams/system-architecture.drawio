        <mxCell id="cognito-group" value="Authentication" style="swimlane;fontStyle=1;fontSize=11;fillColor=#d5e8d4;strokeColor=#82b366;startSize=25;" vertex="1" parent="1">
          <mxGeometry x="270" y="370" width="230" height="160" as="geometry" />
        </mxCell>
        <mxCell id="cognito" value="Cognito User Pool&#xa;&#xa;• PKCE / Hosted UI&#xa;• eu-west-2_VVP8q00KT&#xa;• sfpa-793976-&lt;stage&gt;" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cognito;labelBackgroundColor=none;sketch=0;html=1;fontSize=10;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="cognito-group">
