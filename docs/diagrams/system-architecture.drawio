        </mxCell>
        <mxCell id="s3-spa" value="S3 Bucket&#xa;(React Build)&#xa;&#xa;• Block all public access&#xa;• Served via OAI" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;labelBackgroundColor=none;sketch=0;html=1;fontSize=10;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="cf-spa-group">
